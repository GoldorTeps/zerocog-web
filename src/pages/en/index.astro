---
import Layout from '../../layouts/Layout.astro';
import ZerocogApp from '../../components/ZerocogApp.jsx';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "ZeroCog",
    "url": "https://zerocog.org",
    "email": "zerocogorg@gmail.com",
    "description": "Verified decision architecture for AI systems.",
    "founder": { "@type": "Person", "name": "David Janer Pérez" },
    "foundingDate": "2025",
    "address": { "@type": "PostalAddress", "addressLocality": "Málaga", "addressCountry": "ES" }
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "ZeroCog",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Any",
    "url": "https://zerocog.org/en/",
    "description": "A persistent context and verified-decision layer that lets AI systems operate with real, outcome-based memory without exposing sensitive data or locking you to a vendor.",
    "featureList": [
      "Data sovereignty",
      "AI model independence",
      "Regulatory traceability — AI Act / GDPR",
      "Outcome-based operational memory"
    ],
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/PreOrder",
      "description": "NDA-gated access. Deployment 2026."
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is ZeroCog?",
        "acceptedAnswer": { "@type": "Answer", "text": "ZeroCog is a data architecture that only retains what produced a verified outcome. It is not an AI model. It is the layer that allows existing models to operate on the real, accumulated experience of your organisation." }
      },
      {
        "@type": "Question",
        "name": "How is ZeroCog different from a RAG or semantic-search system?",
        "acceptedAnswer": { "@type": "Answer", "text": "ZeroCog does not retrieve documents by text similarity. It only stores decisions linked to verified outcomes. The distinction is architectural: RAG operates on text; ZeroCog operates on consequences." }
      },
      {
        "@type": "Question",
        "name": "Does my data leave my infrastructure with ZeroCog?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Your verified operational experience stays under your control. ZeroCog works with your data without exposing it to third parties." }
      },
      {
        "@type": "Question",
        "name": "Does ZeroCog lock me into a specific AI model?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. ZeroCog is model-agnostic. It determines what experience your AI models operate on — not which model you use. Change models whenever you want. The decision criterion remains." }
      },
      {
        "@type": "Question",
        "name": "How does ZeroCog comply with the EU AI Act and GDPR?",
        "acceptedAnswer": { "@type": "Answer", "text": "The EU AI Act requires demonstrating what experience a system used as the basis for a recommendation. ZeroCog produces that traceability structurally — not as an afterthought." }
      }
    ]
  }
];
---

<Layout
  title="ZeroCog — The operational memory infrastructure that only persists what worked"
  description="The operational memory infrastructure that only persists what worked. Data sovereignty, model independence, AI Act and GDPR compliance by structural design."
  lang="en"
  canonical="https://zerocog.org/en/"
  jsonLd={jsonLd}
>
  <ZerocogApp client:only="react" lang="en" />
</Layout>
