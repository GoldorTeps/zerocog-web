---
import Layout from '../layouts/Layout.astro';
import ZerocogApp from '../components/ZerocogApp.jsx';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "ZeroCog",
    "url": "https://zerocog.org",
    "email": "zerocogorg@gmail.com",
    "description": "Arquitectura de decisión verificada para sistemas de IA.",
    "founder": { "@type": "Person", "name": "David Janer Pérez" },
    "foundingDate": "2025",
    "address": { "@type": "PostalAddress", "addressLocality": "Málaga", "addressCountry": "ES" }
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "ZeroCog",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Any",
    "url": "https://zerocog.org",
    "description": "Capa de contexto persistente y decisión verificada que permite a sistemas de IA operar con memoria real basada en resultados, sin exponer datos sensibles ni depender de proveedor.",
    "featureList": [
      "Soberanía de datos",
      "Independencia de modelo de IA",
      "Trazabilidad regulatoria AI Act / GDPR",
      "Memoria operativa basada en resultados verificados"
    ],
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/PreOrder",
      "description": "Acceso bajo NDA. Despliegue 2026."
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Qué es ZeroCog?",
        "acceptedAnswer": { "@type": "Answer", "text": "ZeroCog es una arquitectura de datos que solo persiste lo que produjo un resultado verificado. No es un modelo de IA. Es la capa que permite que los modelos existentes operen con experiencia real y acumulada de tu organización." }
      },
      {
        "@type": "Question",
        "name": "¿En qué se diferencia ZeroCog de un sistema RAG o de búsqueda semántica?",
        "acceptedAnswer": { "@type": "Answer", "text": "ZeroCog no recupera documentos por similitud de texto. Solo almacena decisiones vinculadas a resultados verificados. La distinción es arquitectónica: RAG opera sobre texto; ZeroCog opera sobre consecuencias." }
      },
      {
        "@type": "Question",
        "name": "¿Mis datos salen de mi infraestructura con ZeroCog?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Tu experiencia verificada permanece bajo tu control. ZeroCog opera con tus datos sin exponerlos a terceros. La memoria operativa de tu empresa es tuya." }
      },
      {
        "@type": "Question",
        "name": "¿ZeroCog me obliga a usar un modelo de IA concreto?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. ZeroCog es independiente del modelo. Condiciona con qué experiencia opera el modelo, no qué modelo usas. Puedes cambiar de modelo cuando quieras; el criterio permanece." }
      },
      {
        "@type": "Question",
        "name": "¿Cómo cumple ZeroCog con el AI Act y el GDPR?",
        "acceptedAnswer": { "@type": "Answer", "text": "El AI Act europeo exige demostrar en qué experiencia se basó un sistema para recomendar algo. ZeroCog produce esa trazabilidad de forma estructural, no como añadido posterior." }
      }
    ]
  }
];
---

<Layout
  title="ZeroCog — Arquitectura de decisión verificada"
  description="Una arquitectura de datos que solo persiste lo que produjo un resultado verificado. Tu experiencia operativa, activa. Soberanía de datos, independencia de modelo, trazabilidad AI Act."
  lang="es"
  canonical="https://zerocog.org/"
  jsonLd={jsonLd}
>
  <ZerocogApp client:only="react" lang="es" />
</Layout>
